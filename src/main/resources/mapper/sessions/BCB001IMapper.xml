<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bt.hz.domain.sessions.mapper.BCB001IMapper">

    <!-- CUD: 단건 삽입 또는 수정 -->
    <insert id="insertOrUpdate" parameterType="com.bt.hz.domain.sessions.models.BCB001I">
        INSERT INTO BCB001I (id, name, age)
        VALUES (#{id}, #{name}, #{age})
        ON DUPLICATE KEY UPDATE
            name = VALUES(name),
            age = VALUES(age)
    </insert>

    <!-- CUD: 단건 삭제 -->
    <delete id="deleteById">
        DELETE FROM BCB001I
        WHERE id = #{id}
    </delete>

    <!-- CUD: 다건 삭제 -->
    <delete id="deleteAll">
        DELETE FROM BCB001I
        WHERE id IN
        <foreach item="id" collection="keys" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- READ: 단건 조회 -->
    <select id="findById" resultType="com.bt.hz.domain.sessions.models.BCB001I">
        SELECT id, name, age
        FROM BCB001I
        WHERE id = #{id}
    </select>

    <!-- READ: 다건 조회 -->
    <select id="findAllByIds" resultType="com.bt.hz.domain.sessions.models.BCB001I">
        SELECT id, name, age
        FROM BCB001I
        WHERE id IN
        <foreach item="item" collection="keys" open="(" separator="," close=")">
            #{item}
        </foreach>
    </select>

    <!-- READ: 전체 키 조회 (초기 기동 시 사용) -->
    <select id="findAllKeys" resultType="java.lang.String">
        SELECT id FROM BCB001I
    </select>

</mapper>
